DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arcsettle?schema=public"
JWT_SECRET="change-this-in-production"
NEXT_PUBLIC_APP_NAME="ArcSettle"
SETTLEMENT_PROVIDER="mock"
NEXT_PUBLIC_ENABLE_REAL_ARC_SETTLEMENT="false"
CIRCLE_API_KEY=
CIRCLE_API_BASE_URL=https://api.circle.com
CIRCLE_DEV_TOOLS_ENABLED=false

# Circle Entity Secret — required for developer-controlled wallet operations.
# CIRCLE_ENTITY_SECRET is your raw 32-byte hex secret. Server-only, NEVER expose.
# CIRCLE_ENTITY_SECRET_CIPHERTEXT is the RSA-encrypted form used in Circle API calls.
# Generate ciphertext using Circle's documented encryption flow.
# In production, use secure secret storage (Vercel env, AWS Secrets Manager, etc.)
CIRCLE_ENTITY_SECRET=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
