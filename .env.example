# ─────────────────────────────────────────────────────────────────────────────
# ArcSettle Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arcsettle?schema=public"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-in-production"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Settlio"

# ── Settlement Provider ──────────────────────────────────────────────────────
# "mock" = demo/local only (generates fake tx hashes, no real funds)
# "arc-wallet" = validates inputs for real Arc Testnet settlement
#
# For local demo: use "mock"
# For public production: use "mock" with mock flags disabled (real wallet
# settlement is always available when the buyer's wallet conditions are met)
SETTLEMENT_PROVIDER="mock"

# ── Mock Settlement Flags ────────────────────────────────────────────────────
# Controls the "Demo Mock Settlement" button visibility and backend access.
# For local demo/development: set both to "true"
# For public production: set both to "false" to hide mock settlement entirely
NEXT_PUBLIC_ENABLE_MOCK_SETTLEMENT="true"
ENABLE_MOCK_SETTLEMENT="true"

# ── Legacy (no longer required) ──────────────────────────────────────────────
# NEXT_PUBLIC_ENABLE_REAL_ARC_SETTLEMENT is no longer needed.
# The real wallet settlement button appears automatically when wallet
# conditions are met. Retained here for backward compatibility only.
# NEXT_PUBLIC_ENABLE_REAL_ARC_SETTLEMENT="true"

# ── Circle API (optional — for dev/admin wallet scaffolding) ─────────────────
# Circle developer-controlled wallet features are dev/admin only.
# Public users cannot create Circle wallets or initiate Circle transfers.
CIRCLE_API_KEY=""
CIRCLE_API_BASE_URL="https://api.circle.com"
CIRCLE_DEV_TOOLS_ENABLED="false"

# Circle Entity Secret — required for developer-controlled wallet operations.
# CIRCLE_ENTITY_SECRET is your raw 32-byte hex secret. Server-only, NEVER expose.
# The SDK generates fresh ciphertext for each sensitive request automatically.
CIRCLE_ENTITY_SECRET=""
CIRCLE_ENTITY_SECRET_CIPHERTEXT=""
