generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  pending
  approved
  rejected
}

enum InvoiceStatus {
  draft
  pending_approval
  approved
  processing
  settled
  failed
  cancelled
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

model Company {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  countryCode   String
  industry      String
  kycStatus     KycStatus @default(pending)
  walletAddress String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Circle Developer-Controlled Wallet metadata
  circleWalletId         String?
  circleWalletSetId      String?
  circleWalletAddress    String?
  circleWalletBlockchain String?
  circleWalletCreatedAt  DateTime?

  sentInvoices     Invoice[] @relation("SellerInvoices")
  receivedInvoices Invoice[] @relation("BuyerInvoices")

  @@map("companies")
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  sellerId        String
  buyerId         String
  amount          Decimal       @db.Decimal(18, 2)
  currency        String        @default("USDC")
  description     String
  dueDate         DateTime
  status          InvoiceStatus @default(draft)
  approvedAt      DateTime?
  settlementHash  String?
  settlementDate  DateTime?
  settlementFee   Decimal?      @db.Decimal(18, 6)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  seller       Company       @relation("SellerInvoices", fields: [sellerId], references: [id])
  buyer        Company       @relation("BuyerInvoices", fields: [buyerId], references: [id])
  transactions Transaction[]

  @@map("invoices")
}

model Transaction {
  id              String            @id @default(cuid())
  invoiceId       String
  fromWallet      String
  toWallet        String
  amount          Decimal           @db.Decimal(18, 6)
  currency        String            @default("USDC")
  chain           String            @default("arc_testnet")
  transactionHash String?
  status          TransactionStatus @default(pending)
  gasPaidBy       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("transactions")
}

model AuditLog {
  id        String   @id @default(cuid())
  entityId  String
  entity    String
  action    String
  actor     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
